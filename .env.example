# Required
SECRET_KEY=your-very-secret-key-here-change-this

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts (use * to allow all, or your Railway domain)
ALLOWED_HOSTS=*

# MySQL – Railway internal connection (use inside Railway)
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=your-db-password-here
